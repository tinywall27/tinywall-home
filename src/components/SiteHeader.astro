---
const pathname = Astro.url.pathname;
const navItems = [
	{ href: '/', label: '首页' },
	{ href: '/articles/', label: '文章' },
	{ href: '/topics/', label: '主题' },
	{ href: '/archive/', label: '年份' },
];

const isActive = (href: string) =>
	href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="site-header">
	<div class="site-header__inner shell">
		<a class="brand" href="/" aria-label="TinyWall 首页">
			<span class="brand__mark" aria-hidden="true">T</span>
			<span>TinyWall</span>
		</a>

		<nav class="desktop-nav" aria-label="主导航">
			{navItems.map((item) => (
				<a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
					{item.label}
				</a>
			))}
			<a class="search-link" href="/articles/#search">搜索 <span aria-hidden="true">⌕</span></a>
		</nav>

		<details class="mobile-nav">
			<summary aria-label="打开导航菜单"><span aria-hidden="true">菜单</span></summary>
			<nav aria-label="移动端导航">
				{navItems.map((item) => (
					<a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
						{item.label}
					</a>
				))}
				<a href="/articles/#search">搜索文章</a>
			</nav>
		</details>
	</div>
</header>
