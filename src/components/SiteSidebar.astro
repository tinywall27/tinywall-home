---
const pathname = Astro.url.pathname;
interface NavItem {
	href: string;
	label: string;
	external?: boolean;
}

interface NavGroup {
	label: string;
	open: boolean;
	items: NavItem[];
}

const groups: NavGroup[] = [
	{
		label: '内容',
		open: true,
		items: [
			{ href: '/', label: '首页' },
			{ href: '/articles/', label: '全部文章' },
		],
	},
	{
		label: '分类',
		open: true,
		items: [
			{ href: '/topics/', label: '主题' },
			{ href: '/archive/', label: '年份归档' },
		],
	},
	{
		label: '项目',
		open: false,
		items: [
			{ href: 'https://fund.tinywall.cc', label: '跨境基金知识库', external: true },
			{ href: 'https://geo.tinywall.cc', label: '地理 AI 项目', external: true },
		],
	},
];

const isActive = (href: string) =>
	href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<div class="site-sidebar-backdrop" data-nav-close aria-hidden="true"></div>
<aside class="site-sidebar" id="site-sidebar" aria-label="栏目导航">
	<div class="site-sidebar__inner">
		<form class="sidebar-search" action="/articles/" method="get" role="search">
			<label for="sidebar-search">搜索文章</label>
			<div>
				<input id="sidebar-search" name="q" type="search" placeholder="输入关键词…" autocomplete="off" />
				<button type="submit" aria-label="提交搜索">⌕</button>
			</div>
		</form>

		<nav class="sidebar-nav" aria-label="分层目录">
			{groups.map((group) => (
				<details open={group.open || group.items.some((item) => !item.external && isActive(item.href))}>
					<summary>{group.label}<span aria-hidden="true">＋</span></summary>
					<div class="sidebar-nav__items">
						{group.items.map((item) => (
							<a
								href={item.href}
								aria-current={!item.external && isActive(item.href) ? 'page' : undefined}
								target={item.external ? '_blank' : undefined}
								rel={item.external ? 'noopener noreferrer' : undefined}
							>
								<span>{item.label}</span>
								{item.external && <span aria-hidden="true">↗</span>}
							</a>
						))}
					</div>
				</details>
			))}
		</nav>

		<p class="site-sidebar__note">项目 · 阅读 · 归档</p>
	</div>
</aside>
