---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到｜TinyWall" description="你访问的 TinyWall 页面不存在。">
	<section class="not-found shell">
		<p class="not-found__number">404</p>
		<div>
			<p class="eyebrow">PAGE NOT FOUND</p>
			<h1>这面墙上，还没有这一页。</h1>
			<p>地址可能已经变化，也可能只是一次暂时的迷路。</p>
			<a class="button button--primary" href="/">返回首页</a>
		</div>
	</section>
</BaseLayout>
